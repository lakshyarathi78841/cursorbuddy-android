<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/frosted_screen_background"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:src="@drawable/cursorbuddy_app_icon"
            android:layout_marginTop="18dp"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CursorBuddy"
            android:textSize="30sp"
            android:textColor="@color/on_surface"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI-powered screen guide"
            android:textSize="14sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="22dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI Brain"
                android:textSize="17sp"
                android:textColor="@color/on_surface"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_brain"
                android:drawablePadding="8dp"
                android:drawableTint="@color/primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter your Anthropic API key for AI screen understanding."
                android:textSize="12sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/apiKeyInput"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="sk-ant-..."
                    android:textSize="13sp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_secondary"
                    android:inputType="textPassword"
                    android:background="@drawable/input_frost_background"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/saveApiKeyButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Save"
                    android:background="@drawable/button_frost_primary"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:layout_marginStart="10dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Display Over Apps"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/overlayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_secondary" />
            </LinearLayout>
            <Button
                android:id="@+id/overlayButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Grant Overlay Permission"
                android:background="@drawable/button_frost_secondary"
                android:textColor="@color/on_surface"
                android:textAllCaps="false"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Accessibility Service"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/accessibilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_secondary" />
            </LinearLayout>
            <Button
                android:id="@+id/accessibilityButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Enable Accessibility Service"
                android:background="@drawable/button_frost_secondary"
                android:textColor="@color/on_surface"
                android:textAllCaps="false"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Screen Capture (AI Vision)"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/screenCaptureStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_secondary" />
            </LinearLayout>
            <Button
                android:id="@+id/screenCaptureButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Grant Screen Capture"
                android:background="@drawable/button_frost_secondary"
                android:textColor="@color/on_surface"
                android:textAllCaps="false"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start CursorBuddy"
            android:background="@drawable/button_frost_primary"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginTop="14dp"
            android:enabled="false"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant the permissions above to get started."
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:gravity="center"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
